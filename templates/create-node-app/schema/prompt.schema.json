{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "CLI Prompt Generator Schema",
    "type": "object",
    "required": [
        "prompts"
    ],
    "properties": {
        "prompts": {
            "type": "array",
            "minItems": 1,
            "uniqueItemProperties": [
                "name"
            ],
            "items": {
                "$ref": "#/$defs/promptItem"
            },
            "contains": {
                "type": "object",
                "properties": {
                    "type": {
                        "const": "text"
                    },
                    "name": {
                        "const": "name"
                    },
                    "description": {
                        "type": "string"
                    },
                    "prompt": {
                        "type": "object",
                        "required": [
                            "message"
                        ],
                        "properties": {
                            "message": {
                                "type": "string"
                            },
                            "defaultValue": {
                                "type": "string"
                            }
                        }
                    },
                    "validate": {
                        "$ref": "#/$defs/validationConfig"
                    },
                    "skip": {
                        "type": "string"
                    }
                },
                "required": [
                    "type",
                    "name",
                    "description",
                    "prompt"
                ]
            },
            "errorMessage": {
                "uniqueItemProperties": "Each prompt must have a unique 'name'.",
                "contains": "A prompt with name 'name' and type 'text' must exist."
            }
        }
    },
    "$defs": {
        "promptItem": {
            "type": "object",
            "required": [
                "type",
                "description",
                "name",
                "prompt"
            ],
            "additionalProperties": false,
            "properties": {
                "type": {
                    "$ref": "#/$defs/inputType"
                },
                "name": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "prompt": {
                    "$ref": "#/$defs/promptConfig"
                },
                "skip": {
                    "$ref": "#/$defs/jexlExpression"
                },
                "validate": {
                    "$ref": "#/$defs/validationConfig"
                },
                "choices": {
                    "$ref": "#/$defs/choicesConfig"
                },
                "options": {
                    "$ref": "#/$defs/toggleOptions"
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "type": {
                                "enum": [
                                    "select",
                                    "multiselect"
                                ]
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "choices"
                        ],
                        "errorMessage": {
                            "required": "Type 'select' or 'multiselect' requires a 'choices' array."
                        }
                    },
                    "else": {
                        "not": {
                            "required": [
                                "choices"
                            ]
                        },
                        "errorMessage": "The 'choices' property is only allowed for 'select' or 'multiselect' types."
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "toggle"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "options"
                        ],
                        "errorMessage": {
                            "required": "Type 'toggle' requires 'options' (enabled/disabled labels)."
                        }
                    },
                    "else": {
                        "not": {
                            "required": [
                                "options"
                            ]
                        },
                        "errorMessage": "The 'options' property is only allowed for 'toggle' types."
                    }
                }
            ]
        },
        "inputType": {
            "type": "string",
            "enum": [
                "text",
                "select",
                "toggle",
                "multiselect"
            ]
        },
        "promptConfig": {
            "type": "object",
            "required": [
                "message"
            ],
            "properties": {
                "message": {
                    "type": "string"
                },
                "defaultValue": {
                    "$ref": "#/$defs/jexlExpression"
                }
            }
        },
        "validationConfig": {
            "type": "object",
            "required": [
                "expression",
                "error"
            ],
            "properties": {
                "expression": {
                    "$ref": "#/$defs/jexlExpression"
                },
                "error": {
                    "type": "string"
                }
            }
        },
        "jexlExpression": {
            "type": "string"
        },
        "choicesConfig": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string"
                    }
                },
                "required": [
                    "name",
                    "value"
                ],
                "additionalProperties": false
            }
        },
        "choicesConfig2": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string"
            }
        },
        "toggleOptions": {
            "type": "object",
            "required": [
                "enabled",
                "disabled"
            ],
            "properties": {
                "enabled": {
                    "type": "string"
                },
                "disabled": {
                    "type": "string"
                }
            }
        }
    }
}
